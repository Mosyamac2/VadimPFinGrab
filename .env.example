# Copy this file to .env and fill in real values. Do NOT commit .env.

# --- LLM providers ---
# Primary: direct Anthropic API. Leave empty to fall back to OpenRouter only.
ANTHROPIC_API_KEY=
# Fallback: OpenRouter. At least one of the two LLM keys must be set.
OPENROUTER_API_KEY=

# --- Google Drive replication ---
# Created once via `edx auth google-drive` and pasted here.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- Optional cloud OCR ---
YANDEX_VISION_OCR_KEY=
