# Patch 44: environment file for the self-evolve loop.
# Copy to /opt/edx/.env.evolve (chmod 600, owner edx:edx).
#
# DO NOT commit a filled-in copy. NEVER share these tokens.

# --- Required ---
# Long-lived OAuth token for Claude Code in headless mode.
#
# Recommended path (works with both Anthropic Console and Claude.ai
# Pro/Max subscription — NO ANTHROPIC_API_KEY required for evolve):
#
#   sudo -iu edx
#   claude setup-token
#   # → opens a browser; sign in with your Claude.ai account.
#   # → terminal prints a 1-year token (sk-claude-...).
#   # → paste it as CLAUDE_CODE_OAUTH_TOKEN=… below.
#
# Subscription quota: headless usage on a Max plan pulls from the same
# monthly message allocation as web/desktop Claude. NOT separate
# billing. If quota is exhausted, claude returns an error and the tick
# closes with verdict=fail — master is not touched.
#
# When the token expires (~1 year) regenerate with `claude setup-token`.
# The token's auth_id is the Pro/Max subscription, not an API key, so
# the daily/tick budget caps below are upper bounds — actual cost
# is "messages from your plan", not USD spend on api.anthropic.com.
CLAUDE_CODE_OAUTH_TOKEN=

# Master switch — controls whether headless Claude Code runs at all.
#
#   0 (default) → DRY-RUN. Every 5 minutes the loop:
#                    - picks a batch of 3 companies,
#                    - runs the regular `edx update` pipeline (this
#                      DOES use the pipeline's ANTHROPIC_API_KEY for
#                      Metric/Event Extractor LLM calls),
#                    - takes per-ticker before/after snapshots,
#                    - on failure assembles a Diagnostic Bundle,
#                    - writes a row to evolution_ticks,
#                  …but DOES NOT: invoke `claude -p`, create the
#                  evolve/tick-N branch, run make test/canaries, touch
#                  master in any way. CLAUDE_CODE_OAUTH_TOKEN is unused.
#
#   1           → LIVE. On a failing batch the agent is invoked; if all
#                  4 gates (tests + canaries + batch improvement +
#                  MEMORY.md updated) pass, the wrapper does a fast-
#                  forward merge into master and pushes origin.
#
# Recommended: leave =0 for at least 24h after install, inspect
# evolution/runs/<N>/, then flip to 1.
EDX_EVOLVE_AGENT_ENABLED=0

# --- Budgets ---
EDX_EVOLVE_DAILY_BUDGET_USD=25
EDX_EVOLVE_TICK_BUDGET_USD=2

# --- Tuning (sane defaults; touch only if you know what you're doing) ---
# EDX_EVOLVE_BATCH_SIZE=3
# EDX_EVOLVE_COOLDOWN_DAYS=7
# EDX_EVOLVE_MAX_TURNS=25
# EDX_EVOLVE_PIPELINE_TIMEOUT_S=1800
# EDX_EVOLVE_AGENT_TIMEOUT_S=1800
# EDX_EVOLVE_MERGE_XLSX=0
