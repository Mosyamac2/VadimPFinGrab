# Pipeline runtime state — keep .gitkeep so the directory survives
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/processed/_llm_cache/
data/state.sqlite
data/state.sqlite-journal
data/state.sqlite-wal
data/state.sqlite-shm

output/*
!output/.gitkeep

logs/*
!logs/.gitkeep
