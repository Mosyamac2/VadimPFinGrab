# --- Project secrets and runtime artefacts ---
.env

# Pipeline runtime state — keep .gitkeep so the directory survives
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/processed/_llm_cache/
data/state.sqlite
data/state.sqlite-journal
data/state.sqlite-wal
data/state.sqlite-shm

output/*
!output/.gitkeep

logs/*
!logs/.gitkeep

# Patch 38: self-evolution loop
evolution/runs/*
!evolution/runs/.gitkeep
data/state.sqlite.tick*.bak
.env.evolve
.env.proxy
config-evolve/

# Operator-local files that must not pollute the evolve gate's
# whitelist check (these are user state, not loop output, but they
# live in the working tree). Untracked entries here vanish from
# `git ls-files --others --exclude-standard`, which is what
# git_ops.changed_files reads.
DEBUG_EVOLVE_PROMPT.md
IMPLEMENT_*.md
state.sqlite
state.sqlite-*
config/logs/
config/tickers_longlist.yaml
config/tickers_shortlist.yaml
data/canary_baseline.json
